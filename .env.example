# ── LLM ──────────────────────────────────────────────────────────────────────
# Gemini API key (required when --use-llm is passed)
GEMINI_API_KEY=your_api_key_here

# Set to false to disable LLM synthesis globally (default: true)
USE_LLM=true

# Optional overrides for LLM defaults (CLI flags take precedence if supplied)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash-preview
LLM_TIMEOUT_SEC=30

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Default per-tool timeout in seconds (1–180)
PIPELINE_TIMEOUT_SEC=60

# ── API / Docker ───────────────────────────────────────────────────────────────
# Persist report.json/report.md for API requests under output/ mounts
API_PERSIST_REPORTS=true
API_OUTPUT_DIR=/output

# Uvicorn runtime
WORKERS=1